<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Something Went Wrong</title>

  <!-- Tailwind -->
  <script src="https://cdn.tailwindcss.com"></script>

  <style>
    * { box-sizing: border-box; }
    html { scroll-behavior: smooth; }
  </style>
</head>

<body class="min-h-screen bg-gradient-to-br from-[#020617] via-[#0b1222] to-black text-white flex items-center justify-center px-4 py-10 overflow-x-hidden">

  <!-- Background Glow -->
  <div class="fixed inset-0 -z-10 overflow-hidden">
    <div class="absolute -top-40 -left-40 h-96 w-96 rounded-full bg-red-500/20 blur-3xl"></div>
    <div class="absolute -bottom-40 -right-40 h-96 w-96 rounded-full bg-red-500/10 blur-3xl"></div>
  </div>

  <main class="w-full max-w-lg">
    <section
      class="relative rounded-3xl border border-white/10 bg-white/5 backdrop-blur-xl p-6 sm:p-10
             shadow-[0_0_70px_rgba(239,68,68,0.18)]
             hover:shadow-[0_0_90px_rgba(239,68,68,0.28)]
             transition-all duration-500">

      <!-- Top Icon -->
      <div class="flex items-start gap-4">
        <div class="shrink-0 w-12 h-12 rounded-2xl bg-red-500/15 border border-red-500/25
                    flex items-center justify-center shadow-[0_0_30px_rgba(239,68,68,0.25)]">
          <span class="text-2xl">⚠️</span>
        </div>

        <div class="min-w-0">
          <!-- ✅ Title (EJS message) -->
          <h1 class="text-xl sm:text-2xl font-extrabold tracking-tight text-red-300 break-words">
            <%= message %>
          </h1>
          <p class="text-gray-300 mt-2 text-sm sm:text-base leading-relaxed">
            Something didn’t go as expected. Please check the details below and try again.
          </p>
        </div>
      </div>

      <!-- ✅ Main Message -->
      <div
        class="mt-6 rounded-2xl bg-white/5 border border-white/10 p-4 text-sm sm:text-base text-gray-200">
        <p id="mainMessage" class="break-words"></p>
      </div>

      <!-- ✅ Error List -->
      <div class="mt-5">
        <h2 class="text-sm font-bold text-gray-300 mb-3">Details</h2>
        <ul id="errorList" class="space-y-3"></ul>
      </div>

      <!-- ✅ Actions -->
      <div class="mt-8 grid grid-cols-1 sm:grid-cols-2 gap-3">
        <button onclick="goBack()"
          class="w-full py-3 rounded-2xl font-extrabold
                 bg-white/10 hover:bg-white/15 border border-white/10
                 transition active:scale-[0.98]">
          ← Go Back
        </button>

        <a href="/"
          class="w-full py-3 rounded-2xl font-extrabold text-center text-white
                 bg-gradient-to-r from-red-500 to-red-600
                 shadow-[0_0_28px_rgba(239,68,68,0.35)]
                 hover:shadow-[0_0_45px_rgba(239,68,68,0.55)]
                 transition active:scale-[0.98]">
          Go to Login
        </a>
      </div>

      <!-- small hint -->
      <p class="mt-5 text-center text-xs sm:text-sm text-gray-500">
        If this keeps happening, try refreshing the page or checking your internet connection.
      </p>
    </section>
  </main>

  <script>
    // ✅ Replace this with your real server data (window.__ERROR__ etc.)
    // For now: your same simulated response
    const apiResponse = {
      errors: [
        { path: "password", msg: "Invalid value" },
        { path: "username", msg: "Invalid value" }
      ],
      message: "Invalid data or this is not a valid user"
    };

    // Main message
    document.getElementById("mainMessage").innerText = apiResponse.message;

    // Error list rendering
    const errorList = document.getElementById("errorList");

    apiResponse.errors.forEach(err => {
      const li = document.createElement("li");

      li.className =
        "flex items-center justify-between gap-3 rounded-2xl " +
        "bg-white/5 border border-white/10 p-4";

      li.innerHTML = `
        <div class="min-w-0">
          <p class="text-xs uppercase tracking-wider text-sky-300 font-extrabold">${(err.path || "field")}</p>
          <p class="text-sm text-gray-200 mt-1 break-words">${err.msg || "Invalid value"}</p>
        </div>
        <span class="shrink-0 inline-flex items-center px-3 py-1 rounded-full text-xs font-bold
                     bg-red-500/15 border border-red-500/25 text-red-200">
          Error
        </span>
      `;

      errorList.appendChild(li);
    });

    function goBack() {
      window.history.back();
    }
  </script>

</body>
</html>