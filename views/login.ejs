<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
  <link href="https://cdn.jsdelivr.net/npm/flowbite@4.0.1/dist/flowbite.min.css" rel="stylesheet" />
  <link href="https://cdn.jsdelivr.net/npm/remixicon@4.7.0/fonts/remixicon.css" rel="stylesheet" />
  <title>Shiraj's Drive - Login</title>
</head>

<body class="min-h-screen w-full bg-gray-900 text-white flex items-center justify-center px-4 py-10 overflow-x-hidden">

  <!-- Background glow -->
  <div class="fixed inset-0 -z-10 overflow-hidden">
    <div class="absolute -top-40 -left-40 h-96 w-96 rounded-full bg-emerald-500/20 blur-3xl"></div>
    <div class="absolute -bottom-40 -right-40 h-96 w-96 rounded-full bg-emerald-500/10 blur-3xl"></div>
  </div>

  <main class="w-full max-w-md">
    <form id="loginForm"
      class="w-full bg-gray-950/70 backdrop-blur-xl border border-gray-800 rounded-3xl
             shadow-[0_0_28px_rgba(16,185,129,0.25)]
             hover:shadow-[0_0_45px_rgba(16,185,129,0.32)]
             transition-all duration-300 p-6 sm:p-10 flex flex-col gap-5"
      action="/" method="post" novalidate>

      <!-- Header -->
      <div class="text-center mb-1">
        <div class="flex justify-center mb-4">
          <img src="/logo.png"
               class="h-14 w-14 rounded-full shadow-[0_0_25px_rgba(16,185,129,0.6)]" />
        </div>
        <h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight">Welcome back</h1>
        <p class="text-gray-400 mt-2 text-sm sm:text-base">Login to continue to Shiraj’s Drive</p>
      </div>

      <!-- Username -->
      <div>
        <label for="username" class="block mb-2 text-sm sm:text-base font-semibold text-gray-200">
          Username
        </label>

        <div class="relative">
          <span class="absolute left-4 top-1/2 -translate-y-1/2 text-gray-400">
            <i class="ri-user-3-line"></i>
          </span>
          <input type="text" id="username" name="username" autocomplete="username" required
            placeholder="shiraj mujawar"
            class="w-full pl-11 pr-4 py-3 text-sm sm:text-base rounded-2xl bg-gray-900
                   border border-gray-800 outline-none
                   focus:border-emerald-400 focus:ring-2 focus:ring-emerald-400/40
                   placeholder-gray-500 transition" />
        </div>
      </div>

      <!-- Password -->
      <div>
        <label for="password" class="block mb-2 text-sm sm:text-base font-semibold text-gray-200">
          Password
        </label>

        <div class="relative">
          <span class="absolute left-4 top-1/2 -translate-y-1/2 text-gray-400">
            <i class="ri-lock-2-line"></i>
          </span>

          <input type="password" id="password" name="password" autocomplete="current-password" required
            placeholder="••••••••"
            class="w-full pl-11 pr-12 py-3 text-sm sm:text-base rounded-2xl bg-gray-900
                   border border-gray-800 outline-none
                   focus:border-emerald-400 focus:ring-2 focus:ring-emerald-400/40
                   placeholder-gray-500 transition" />

          <button type="button" id="togglePass"
            class="absolute right-3 top-1/2 -translate-y-1/2 px-2 py-1 rounded-lg
                   text-gray-300 hover:text-white hover:bg-white/10 transition"
            aria-label="Toggle password visibility">
            <i id="toggleIcon" class="ri-eye-line text-xl"></i>
          </button>
        </div>

        <p id="errorMsg" class="text-red-400 text-sm mt-2 hidden"></p>
      </div>

      <!-- Submit Button -->
      <button id="submitBtn" type="submit"
        class="w-full py-3 rounded-2xl font-extrabold text-black
               bg-emerald-500 hover:bg-emerald-400
               shadow-[0_0_25px_rgba(16,185,129,0.35)]
               hover:shadow-[0_0_40px_rgba(16,185,129,0.5)]
               active:scale-[0.99]
               transition disabled:opacity-50 disabled:cursor-not-allowed">
        Login
      </button>

      <!-- Links -->
      <div class="flex items-center justify-between text-sm text-gray-300">
        <a href="/register" class="text-emerald-400 hover:text-emerald-300 underline font-semibold">
          Create an account
        </a>
        <a href="/forgot" class="text-gray-400 hover:text-gray-200 underline">
          Forgot password?
        </a>
      </div>
    </form>
  </main>

  <script>
    const username = document.getElementById("username");
    const password = document.getElementById("password");
    const submitBtn = document.getElementById("submitBtn");
    const errorMsg = document.getElementById("errorMsg");

    const togglePass = document.getElementById("togglePass");
    const toggleIcon = document.getElementById("toggleIcon");

    // Password toggle
    togglePass.addEventListener("click", () => {
      const isHidden = password.type === "password";
      password.type = isHidden ? "text" : "password";
      toggleIcon.className = isHidden ? "ri-eye-off-line text-xl" : "ri-eye-line text-xl";
    });

    // Basic front validation (optional)
    function validate() {
      const u = username.value.trim().length >= 3;
      const p = password.value.length >= 6;

      if (!u || !p) {
        errorMsg.textContent = "Please enter valid username and password.";
        errorMsg.classList.remove("hidden");
      } else {
        errorMsg.classList.add("hidden");
      }
      // do not block submit if you want server-side only:
      // submitBtn.disabled = !(u && p);
    }

    username.addEventListener("input", validate);
    password.addEventListener("input", validate);
  </script>

  <script src="https://cdn.jsdelivr.net/npm/flowbite@4.0.1/dist/flowbite.min.js"></script>
</body>
</html>