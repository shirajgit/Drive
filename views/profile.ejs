<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <script src="https://cdn.tailwindcss.com"></script>
  <title>Profile</title>
</head>

<body class="min-h-screen bg-gradient-to-br from-[#020617] via-[#0f172a] to-[#020617]
             text-white overflow-x-hidden">

  <!-- ✅ Top Bar (mobile friendly) -->
  <header class="w-full px-4 sm:px-6 pt-6 flex items-center justify-between">
    <!-- Back -->
    <button onclick="history.back()"
      class="flex items-center gap-2 px-4 py-2.5 rounded-xl bg-white/10 backdrop-blur-md
             border border-white/15 text-white font-semibold
             hover:bg-white/20 hover:shadow-[0_0_25px_rgba(16,185,129,0.55)]
             active:scale-[0.98] transition">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5"
           fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
      </svg>
      Back
    </button>

    <!-- Home -->
    <a href="/home"
      class="px-4 py-2.5 rounded-xl bg-white/10 backdrop-blur-md border border-white/15
             font-semibold hover:bg-white/20 transition">
      Home
    </a>
  </header>

  <!-- ✅ Center Layout -->
  <main class="min-h-[calc(100vh-80px)] flex items-center justify-center px-4 sm:px-6 py-10">
    <section
      class="relative w-full max-w-xl p-6 sm:p-10 rounded-3xl
             bg-white/5 backdrop-blur-xl
             border border-white/10
             shadow-[0_0_60px_rgba(16,185,129,0.22)]
             hover:shadow-[0_0_90px_rgba(16,185,129,0.32)]
             transition-all duration-500">

      <!-- Glow Orbs -->
      <div class="absolute -top-16 -left-16 w-40 h-40 rounded-full bg-emerald-500/20 blur-3xl"></div>
      <div class="absolute -bottom-16 -right-16 w-40 h-40 rounded-full bg-emerald-500/10 blur-3xl"></div>

      <!-- Avatar -->
      <div class="flex justify-center mb-6">
        <div class="relative">
          <img src="/logo.png"
               class="w-24 h-24 sm:w-28 sm:h-28 rounded-full border-4 border-emerald-400
                      shadow-[0_0_30px_rgba(16,185,129,0.8)] object-cover" />
          <!-- online dot -->
          <span class="absolute bottom-1 right-1 w-5 h-5 bg-emerald-400 rounded-full border-2 border-black"></span>
        </div>
      </div>

      <!-- Name -->
      <h1 class="text-2xl sm:text-3xl font-extrabold text-center tracking-wide">
        <%= user.username %>
      </h1>
      <p class="text-center text-gray-400 mt-1 mb-8">
        • Cloud Drive
      </p>

      <!-- Info -->
      <div class="space-y-3 sm:space-y-4">
        <!-- Email -->
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2
                    bg-white/5 p-4 rounded-2xl border border-white/10">
          <span class="text-gray-400 text-sm sm:text-base">Email</span>
          <span class="font-semibold break-all"><%= user.email %></span>
        </div>

        <!-- Username -->
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2
                    bg-white/5 p-4 rounded-2xl border border-white/10">
          <span class="text-gray-400 text-sm sm:text-base">Username</span>
          <span class="font-semibold">@<%= user.username %></span>
        </div>

        <!-- Upload count -->
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2
                    bg-white/5 p-4 rounded-2xl border border-white/10">
          <span class="text-gray-400 text-sm sm:text-base">Uploaded Files</span>

          <span class="inline-flex items-center gap-2 font-extrabold text-lg sm:text-xl text-emerald-300">
            <span class="w-2.5 h-2.5 rounded-full bg-emerald-400 shadow-[0_0_18px_rgba(16,185,129,0.7)]"></span>
            <%= files.length %>
          </span>
        </div>
      </div>

      <!-- Actions -->
      <div class="mt-8 grid grid-cols-1 sm:grid-cols-2 gap-3 sm:gap-4">
        <a href="/files"
           class="py-3 rounded-2xl font-bold text-center
                  bg-white/10 hover:bg-white/15 border border-white/10
                  hover:shadow-[0_0_25px_rgba(16,185,129,0.35)]
                  active:scale-[0.98] transition">
          View Files
        </a>

        <a href="/"
           class="py-3 rounded-2xl font-bold text-center
                  bg-gradient-to-r from-rose-500 via-red-500 to-red-600
                  shadow-[0_0_30px_rgba(239,68,68,0.55)]
                  hover:shadow-[0_0_55px_rgba(239,68,68,0.85)]
                  hover:scale-[1.02]
                  active:scale-[0.98]
                  transition">
          Logout
        </a>
      </div>

    </section>
  </main>

</body>
</html>