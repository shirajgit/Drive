<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Shiraj's Drive – Home</title>

  <!-- Tailwind -->
  <script src="https://cdn.tailwindcss.com"></script>
  <!-- Remix Icons (optional) -->
  <link href="https://cdn.jsdelivr.net/npm/remixicon@4.7.0/fonts/remixicon.css" rel="stylesheet"/>

</head>

<body class="min-h-screen bg-gradient-to-br from-[#020617] via-[#0f172a] to-[#020617] text-white overflow-x-hidden">

  <!-- Background glow -->
  <div class="fixed inset-0 -z-10 overflow-hidden">
    <div class="absolute -top-40 -left-40 h-96 w-96 rounded-full bg-emerald-500/20 blur-3xl"></div>
    <div class="absolute -bottom-40 -right-40 h-96 w-96 rounded-full bg-emerald-500/10 blur-3xl"></div>
  </div>

  <!-- Navbar -->
  <header class="sticky top-0 z-50 bg-black/60 backdrop-blur-xl border-b border-white/10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 h-20 flex items-center justify-between">

      <a href="/home" class="flex items-center gap-3">
        <img src="/logo.png" alt="logo"
             class="w-10 h-10 rounded-full shadow-[0_0_22px_rgba(16,185,129,0.6)]" />
        <span class="text-xl sm:text-2xl font-extrabold tracking-tight">Shiraj’s Drive</span>
      </a>

      <div class="flex items-center gap-3">
        <a href="/files"
          class="px-4 py-2.5 rounded-xl font-bold text-black
                 bg-emerald-500 hover:bg-emerald-400
                 shadow-[0_0_20px_rgba(16,185,129,0.45)]
                 hover:shadow-[0_0_35px_rgba(16,185,129,0.65)]
                 transition">
          <span class="inline-flex items-center gap-2">
            <i class="ri-upload-2-line text-lg"></i>
            Upload
          </span>
        </a>
      </div>

    </div>
  </header>

  <main class="max-w-7xl mx-auto px-4 sm:px-6 py-12 sm:py-16">

    <!-- Hero -->
    <section class="relative overflow-hidden rounded-3xl border border-white/10 bg-white/5 backdrop-blur-xl p-8 sm:p-12
                    shadow-[0_0_70px_rgba(16,185,129,0.12)]">
      <div class="absolute -top-10 -right-10 w-60 h-60 rounded-full bg-emerald-500/15 blur-3xl"></div>

      <div class="max-w-2xl">
        <p class="inline-flex items-center gap-2 text-emerald-300 font-semibold bg-emerald-500/10
                  border border-emerald-500/20 px-3 py-1 rounded-full mb-5">
          <span class="w-2 h-2 rounded-full bg-emerald-400 shadow-[0_0_12px_rgba(16,185,129,0.8)]"></span>
          Cloud Drive
        </p>

        <h1 class="text-3xl sm:text-5xl font-extrabold leading-tight">
          Your files. <span class="text-emerald-300">Safe.</span> Fast. Everywhere.
        </h1>

        <p class="text-gray-300 mt-4 text-base sm:text-lg leading-relaxed">
          Store your images, videos, documents and backups securely in one place.
          Access them anytime, from any device.
        </p>

        <div class="mt-7 flex flex-col sm:flex-row gap-3">
          <a href="/files"
            class="px-6 py-3 rounded-2xl font-extrabold text-black text-center
                   bg-emerald-500 hover:bg-emerald-400
                   shadow-[0_0_25px_rgba(16,185,129,0.45)]
                   hover:shadow-[0_0_40px_rgba(16,185,129,0.7)]
                   transition">
            Upload Your File →
          </a>

          <a href="/files"
            class="px-6 py-3 rounded-2xl font-bold text-center
                   bg-white/10 hover:bg-white/15 border border-white/10
                   transition">
            Browse Files
          </a>
        </div>
      </div>
    </section>

    <!-- Cards -->
    <section class="mt-10 sm:mt-14 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 sm:gap-6">
      <!-- Card -->
      <div class="rounded-3xl border border-white/10 bg-white/5 backdrop-blur-xl p-6
                  hover:shadow-[0_0_40px_rgba(16,185,129,0.18)] transition">
        <div class="w-12 h-12 rounded-2xl bg-emerald-500/15 border border-emerald-500/20
                    flex items-center justify-center mb-4">
          <i class="ri-folder-3-line text-2xl text-emerald-300"></i>
        </div>
        <h3 class="text-lg font-extrabold">Store Anything</h3>
        <p class="text-gray-300 mt-2 text-sm leading-relaxed">
          Upload images, videos, PDFs, ZIPs and more without hassle.
        </p>
      </div>

      <div class="rounded-3xl border border-white/10 bg-white/5 backdrop-blur-xl p-6
                  hover:shadow-[0_0_40px_rgba(16,185,129,0.18)] transition">
        <div class="w-12 h-12 rounded-2xl bg-emerald-500/15 border border-emerald-500/20
                    flex items-center justify-center mb-4">
          <i class="ri-flashlight-line text-2xl text-emerald-300"></i>
        </div>
        <h3 class="text-lg font-extrabold">Fast Access</h3>
        <p class="text-gray-300 mt-2 text-sm leading-relaxed">
          Quick preview + instant downloads whenever you need.
        </p>
      </div>

      <div class="rounded-3xl border border-white/10 bg-white/5 backdrop-blur-xl p-6
                  hover:shadow-[0_0_40px_rgba(16,185,129,0.18)] transition">
        <div class="w-12 h-12 rounded-2xl bg-emerald-500/15 border border-emerald-500/20
                    flex items-center justify-center mb-4">
          <i class="ri-shield-check-line text-2xl text-emerald-300"></i>
        </div>
        <h3 class="text-lg font-extrabold">Secure Storage</h3>
        <p class="text-gray-300 mt-2 text-sm leading-relaxed">
          Your files are protected with modern authentication.
        </p>
      </div>

      <div class="rounded-3xl border border-white/10 bg-white/5 backdrop-blur-xl p-6
                  hover:shadow-[0_0_40px_rgba(16,185,129,0.18)] transition">
        <div class="w-12 h-12 rounded-2xl bg-emerald-500/15 border border-emerald-500/20
                    flex items-center justify-center mb-4">
          <i class="ri-cloud-line text-2xl text-emerald-300"></i>
        </div>
        <h3 class="text-lg font-extrabold">Cloud Sync</h3>
        <p class="text-gray-300 mt-2 text-sm leading-relaxed">
          Access your drive from anywhere, anytime.
        </p>
      </div>
    </section>

    <!-- CTA -->
    <section class="mt-10 sm:mt-14 rounded-3xl border border-white/10 bg-white/5 backdrop-blur-xl p-8 sm:p-10
                    flex flex-col sm:flex-row items-start sm:items-center justify-between gap-6">
      <div>
        <h3 class="text-2xl font-extrabold">Start uploading your files</h3>
        <p class="text-gray-300 mt-2">
          No files yet? Upload your first file and build your drive.
        </p>
      </div>

      <a href="/files"
        class="w-full sm:w-auto px-6 py-3 rounded-2xl font-extrabold text-black text-center
               bg-emerald-500 hover:bg-emerald-400
               shadow-[0_0_25px_rgba(16,185,129,0.45)]
               hover:shadow-[0_0_40px_rgba(16,185,129,0.7)]
               transition">
        Upload Your File →
      </a>
    </section>

    <!-- Footer -->
    <footer class="mt-12 text-center text-gray-500 text-sm">
      © <span id="year"></span> Shiraj’s Drive. All rights reserved.
    </footer>
  </main>

  <script>
    document.getElementById("year").textContent = new Date().getFullYear();
  </script>
</body>
</html>