<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
 
  <title>Shiraj`s Drive</title>
      <link rel="icon"  href="/favicon.ico" /> 
  <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <link href="https://cdn.jsdelivr.net/npm/flowbite@4.0.1/dist/flowbite.min.css" rel="stylesheet" />
<link
    href="https://cdn.jsdelivr.net/npm/remixicon@4.7.0/fonts/remixicon.css"
    rel="stylesheet"
/>

  <link rel="stylesheet" href="/sidebar.css">
  
</head>
 
 

<body class="bg-gray-900 text-white overflow-x-hidden">

  <!-- ===================== TOP NAVBAR ===================== -->
  <header class="fixed top-0 left-0 z-50 w-full h-20 bg-black/90 backdrop-blur border-b border-gray-800">
    <div class="h-full max-w-7xl mx-auto px-4 flex items-center justify-between">

      <!-- Left: Mobile Menu + Brand -->
      <div class="flex items-center gap-3">
        <!-- Mobile Menu Button -->
        <button id="menuBtn"
          class="lg:hidden p-2 rounded-lg border border-gray-700 hover:border-emerald-400 transition">
          <i class="ri-sidebar-fold-line text-2xl"></i>
        </button>

        <!-- Brand -->
        <a href="/home" class="flex items-center gap-3">
          <img src="/logo.png"
            class="h-10 w-10 rounded-full shadow-[0_0_20px_rgba(16,185,129,0.7)] hover:shadow-[0_0_35px_6px_rgba(16,185,129,0.5)] transition" />
          <span class="text-xl sm:text-2xl font-bold">Shiraj’s Drive</span>
        </a>
      </div>

      <!-- Right: Upload Button -->
      <button onclick="showpop()"
        class="bg-emerald-500 hover:bg-emerald-400 text-black font-bold px-4 py-2 rounded-xl shadow-[0_0_20px_rgba(16,185,129,0.6)] hover:shadow-[0_0_35px_6px_rgba(16,185,129,0.45)] transition">
        Upload File
      </button>
    </div>
  </header>

  <!-- ===================== MOBILE SIDEBAR + OVERLAY ===================== -->
  <div id="overlay" class="fixed inset-0 bg-black/60 hidden z-40 lg:hidden"></div>

  <aside id="mobileSidebar"
    class="fixed top-0 left-0 z-50 h-screen w-72 bg-black border-r border-gray-800 transform -translate-x-full transition-transform duration-300 lg:hidden">
    <div class="flex items-center gap-3 px-6 py-5 border-b border-gray-800">
      <img src="/logo.png" class="w-10 h-10 rounded-full" />
      <h2 class="text-lg font-semibold">Shiraj’s Drive</h2>
    </div>

    <nav class="p-4 space-y-2">
      <a href="/files" class="sidebar-link"><i class="ri-home-4-line"></i> All Files</a>
      <a href="/images" class="sidebar-link"><i class="ri-image-line"></i> Images</a>
      <a href="/audio" class="sidebar-link"><i class="ri-music-line"></i> Music</a>
      <a href="/videos" class="sidebar-link"><i class="ri-video-line"></i> Videos</a>
      <a href="/pdfs" class="sidebar-link"><i class="ri-file-pdf-line"></i> PDFs</a>
      <a href="/zip" class="sidebar-link"><i class="ri-folder-zip-line"></i> ZIPs</a>
      <a href="/apks" class="sidebar-link"><i class="ri-android-line"></i> APKs</a>
      <a href="/profile" class="sidebar-link"><i class="ri-account-circle-line"></i> Profile</a>
    </nav>
  </aside>

  <!-- ===================== DESKTOP SIDEBAR ===================== -->
  <aside class="hidden lg:block fixed top-20 left-0 h-[calc(100vh-80px)] w-64 bg-black border-r border-gray-800">
   
    <nav class="p-4 space-y-5">
      <a href="/files" class="sidebar-link"><i class="ri-home-4-line"></i> All Files</a>
      <a href="/images" class="sidebar-link"><i class="ri-image-line"></i> Images</a>
      <a href="/audio" class="sidebar-link"><i class="ri-music-line"></i> Music</a>
      <a href="/videos" class="sidebar-link"><i class="ri-video-line"></i> Videos</a>
      <a href="/pdfs" class="sidebar-link"><i class="ri-file-pdf-line"></i> PDFs</a>
      <a href="/zip" class="sidebar-link"><i class="ri-folder-zip-line"></i> ZIPs</a>
      <a href="/apks" class="sidebar-link"><i class="ri-android-line"></i> APKs</a>
      <a href="/profile" class="sidebar-link"><i class="ri-account-circle-line"></i> Profile</a>
    </nav>
  </aside>

  <!-- ===================== MAIN CONTENT ===================== -->
  <main class="pt-24 lg:pl-64">
    <div class="max-w-7xl mx-auto px-4 pb-10">

      <!-- Title + Count -->
      <div class="flex items-center gap-3 mb-6">
        <h1 class="text-2xl font-extrabold text-gray-200">Files</h1>
        <span
          class="px-3 py-1 text-sm font-bold text-emerald-300 rounded-full bg-emerald-500/10 border border-emerald-500/30 shadow-[0_0_12px_rgba(16,185,129,0.5)]">
          <%= files.length %>
        </span>
      </div>

      <% if (!files || files.length === 0) { %>
      <!-- EMPTY STATE -->
      <section class="min-h-[60vh] flex items-center ml-20 lg:ml-80 justify-center">
        <div
          class="relative max-w-md w-full p-10 rounded-3xl bg-white/5 backdrop-blur border border-white/10 shadow-[0_0_60px_rgba(16,185,129,0.15)] hover:shadow-[0_0_80px_rgba(16,185,129,0.25)] transition">
          <div class="absolute -top-10 left-1/2 -translate-x-1/2 w-32 h-32 rounded-full bg-emerald-500/25 blur-3xl"></div>

          <div class="flex justify-center mb-6">
            <div
              class="w-20 h-20 rounded-2xl bg-gradient-to-br from-emerald-400 to-green-600 flex items-center justify-center shadow-[0_0_35px_rgba(16,185,129,0.7)]">
              <i class="ri-upload-2-line text-4xl"></i>
            </div>
          </div>

          <h2 class="text-3xl font-extrabold text-center mb-2">No files yet</h2>
          <p class="text-center text-gray-400 mb-8">Upload your first file and keep everything in one place.</p>

          <button onclick="showpop()"
            class="w-full py-4 rounded-2xl text-lg font-semibold bg-gradient-to-r from-emerald-400 to-green-600 text-black shadow-[0_0_35px_rgba(16,185,129,0.55)] hover:shadow-[0_0_60px_rgba(16,185,129,0.8)] transition">
            Upload your file →
          </button>
        </div>
      </section>
      <% } else { %>

      <!-- FILE GRID -->
      <section class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4 sm:gap-6">
        <% files.forEach(file => { %>
        
        <article
          class="bg-gray-950/60 border border-gray-800 rounded-2xl p-3 shadow-[0_0_25px_rgba(16,185,129,0.12)] hover:shadow-[0_12px_35px_rgba(16,185,129,0.3)] hover:scale-[1.02] transition flex flex-col">

          <!-- Preview -->
          <% if (file.fileType && file.fileType.startsWith('image/')) { %>
              <a href="<%= file.fileUrl %>" target="_blank" class="block rounded-xl overflow-hidden"> 
    
            <img src="<%= file.fileUrl %>" class="h-24 sm:h-40 w-full object-cover" />
          </a>

          <% } else if (file.fileType === 'application/pdf') { %>
          <div class="h-24 sm:h-40 rounded-xl bg-red-500/10 border border-red-500/20 flex flex-col items-center justify-center">
            <i class="ri-file-pdf-2-line text-4xl sm:text-6xl text-red-300"></i>
            <p class="text-sm mt-2 text-red-200 font-semibold">PDF</p>
          </div>

          <% } else if (file.fileType && file.fileType.includes('video')) { %>
            <a href="<%= file.fileUrl %>" target="_blank" class="block rounded-xl overflow-hidden">
          <div class="h-24 sm:h-40 rounded-xl bg-purple-500/10 border border-purple-500/20 flex flex-col items-center justify-center">
            <i class="ri-folder-video-fill text-4xl sm:text-6xl text-purple-300"></i>
            <p class="text-sm mt-2 text-purple-200 font-semibold">Video</p>
          </div></a>

          <% } else if (file.fileType && file.fileType.includes('zip')) { %>
            <a href="<%= file.fileUrl %>" target="_blank" class="block rounded-xl overflow-hidden">
          <div class="h-24 sm:h-40 rounded-xl bg-yellow-500/10 border border-yellow-500/20 flex flex-col items-center justify-center">
            <i class="ri-folder-zip-line text-4xl sm:text-6xl text-yellow-300"></i>
            <p class="text-sm mt-2 text-yellow-200 font-semibold">ZIP</p>
          </div></a>

          <% } else if (file.fileType && file.fileType.includes('audio')) { %>
            
            <a href="<%= file.fileUrl %>" target="_blank" class="block rounded-xl overflow-hidden">
          <div class="h-24 sm:h-40 rounded-xl bg-indigo-500/10 border border-indigo-500/20 flex flex-col items-center justify-center">
            <i class="ri-file-music-line text-4xl sm:text-6xl text-indigo-300"></i>
            <p class="text-sm mt-2 text-indigo-200 font-semibold">Audio</p>
          </div>
                </a>
          <% } else { %>
              <a href="<%= file.fileUrl %>" target="_blank" class="block rounded-xl overflow-hidden">
          <div class="h-24 sm:h-40 rounded-xl bg-gray-800 flex items-center justify-center">
            <i class="ri-file-line text-4xl sm:text-6xl text-gray-200"></i>
          </div>
          </a>
          <% } %>

          <!-- Name -->
          <p class="mt-3 font-semibold text-base sm:text-lg truncate text-gray-100">
            <%= file.fileName %>
          </p>

          <!-- Actions -->
          <div class="mt-3 grid grid-cols-2 gap-2">
            <a href="<%= file.fileUrl %>" target="_blank"
              class="text-center bg-emerald-500 hover:bg-emerald-400 text-black font-bold py-2 rounded-lg transition">
              View
            </a>
            <form action="/delete-file/<%= file._id %>" method="POST">
              <button type="submit"
                class="w-full bg-red-600 hover:bg-red-500 text-white font-bold py-2 rounded-lg transition">
                Delete
              </button>
            </form>
          </div>
        </article>
        <% }) %>
      </section>

      <% } %>
    </div>
  </main>

  <!-- ===================== UPLOAD POPUP ===================== -->
  <div class="pop hidden fixed inset-0 flex items-center justify-center backdrop-blur-sm bg-black/60 z-50">
    <form action="/files" method="post" enctype="multipart/form-data" id="uploadForm"
      class="bg-gray-950 border border-gray-800 rounded-2xl p-6 w-11/12 sm:w-[420px] shadow-lg relative">

      <button type="button" onclick="hidepop()"
        class="absolute top-4 right-4 text-white bg-red-500 hover:bg-red-600 rounded-full p-2 transition">
        <i class="ri-close-line text-xl"></i>
      </button>

      <h3 class="text-xl font-bold mb-4">Upload a file</h3>

      <label for="dropzone-file"
        class="flex flex-col items-center justify-center w-full h-56 bg-gray-900 border-2 border-dashed border-gray-700 rounded-2xl cursor-pointer hover:border-emerald-400 hover:bg-gray-900/60 transition">
        <div class="flex flex-col items-center justify-center text-gray-200">
          <i class="ri-upload-cloud-2-line text-4xl text-emerald-300 mb-3"></i>
          <p class="text-sm"><span class="font-semibold">Click to upload</span> or drag & drop</p>
          <p class="text-xs text-gray-400 mt-2">SVG, PNG, JPG, GIF, PDF, MP3, MP4, ZIP, APK (MAX. 50MB)</p>
        </div>
        <input id="dropzone-file" type="file" class="hidden" name="file" />
      </label>

      <button type="submit" id="uploadBtn"
        class="mt-4 w-full bg-emerald-500 hover:bg-emerald-400 text-black font-bold py-3 rounded-xl transition">
        Upload File
      </button>

      <p id="uploadStatus" class="text-sm text-gray-300 hidden mt-3"></p>
      <div class="w-full bg-gray-800 rounded-full h-2 hidden mt-2" id="progressWrap">
        <div id="progressBar" class="bg-emerald-500 h-2 rounded-full w-0 transition-all"></div>
      </div>
    </form>
  </div>

  <!-- ===================== STYLES (small helper classes) ===================== -->
  <style>
    .sidebar-link {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 12px 14px;
      border-radius: 12px;
      color: #e5e7eb;
      border: 1px solid rgba(31, 41, 55, .8);
      background: rgba(17, 24, 39, .35);
      transition: all .2s ease;
      font-weight: 600;
    }

    .sidebar-link:hover {
      border-color: rgba(16, 185, 129, .55);
      box-shadow: 0 0 0 3px rgba(16, 185, 129, .12);
      transform: translateX(2px);
    }
  </style>

  <!-- ===================== SCRIPT (Mobile sidebar toggle) ===================== -->
  <script>
    const menuBtn = document.getElementById("menuBtn");
    const sidebar = document.getElementById("mobileSidebar");
    const overlay = document.getElementById("overlay");

    function openSidebar() {
      sidebar.classList.remove("-translate-x-full");
      overlay.classList.remove("hidden");
      document.body.classList.add("overflow-hidden");
    }

    function closeSidebar() {
      sidebar.classList.add("-translate-x-full");
      overlay.classList.add("hidden");
      document.body.classList.remove("overflow-hidden");
    }

    menuBtn?.addEventListener("click", openSidebar);
    overlay?.addEventListener("click", closeSidebar);

    // Close on ESC
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") closeSidebar();
    });
  </script>

  <!-- Your existing scripts -->
  <script src="https://cdn.jsdelivr.net/npm/flowbite@4.0.1/dist/flowbite.min.js"></script>
  <script src="/home.js"></script>

</body>

</html>
